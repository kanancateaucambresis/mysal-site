---
import "../styles/global.css";
import Header from "../components/Header.astro";
import BackHome from "../components/BackHome.astro";
import Footer from "../components/Footer.astro";
import { getPlayers } from "../lib/players.js";

const players = await getPlayers();

const goalRanking = [...players]
  .sort((a, b) => b.goals - a.goals);

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function isLegend(player) {
  return player.rank?.toLowerCase() === "legend";
}
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GOAL RANKING | MYSAL STATS</title>
</head>

<body>
<main class="container">

  <Header />

  <section class="ranking-section">
    <div class="section-head">
      <h2>GOAL RANKING</h2>
      <span>ALL PLAYERS</span>
    </div>

    <div class="ranking-list">
      {goalRanking.map((player, index) => (
        <a class={`ranking-row ${isLegend(player) ? "is-legend" : ""}`} href={`/player/${player.id}`}>
          <div class="rank">{String(index + 1).padStart(2, "0")}</div>

          <img
            class="avatar"
            src={imagePath(player)}
            alt={player.name}
            onerror="this.src='/players/placeholder-player.webp'"
          />

          <div class="name-area">
            <strong>{player.name}</strong>
            <span>{player.id} ｜ {player.rank.toUpperCase()}</span>
          </div>

          <div class="goals">
            <strong>{player.goals}</strong>
            <span>GOALS</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BackHome />

  <Footer />

</main>
</body>
</html>