---
import "../styles/global.css";
import "../styles/goals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import { getPageData } from "../lib/players.js";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=30, stale-while-revalidate=60"
);

const { players, siteData } = await getPageData();

const goalRanking = [...players].sort((a, b) => {
  if (b.goals !== a.goals) return b.goals - a.goals;
  if (b.total !== a.total) return b.total - a.total;
  return a.id.localeCompare(b.id, undefined, { numeric: true });
});

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function isLegend(player) {
  return player.rank?.toLowerCase() === "legend";
}

function rankClass(player) {
  return `rank-${player.rank?.toLowerCase()}`;
}
---

<Layout
  title="GOALS | MYSAL STATS"
  description="マイサルの月間得点ランキング。TOP 10 SCORERSを掲載しています。"
>
  <main class="container">
    <Header active="goals" />

    <section class="goals-card">
      <div class="goals-card-head">
        <div class="month-title">{siteData.displayMonth}</div>

        <div class="updated">
          <span>UPDATED</span>
          <strong>{siteData.updatedDate}</strong>
        </div>
      </div>

      <div class="card-divider"></div>

      <h1 class="goals-title">TOP 10 SCORERS</h1>

      <div class="goals-list">
        {goalRanking.slice(0, 10).map((player, index) => (
          <a
            class={`goals-row ${index === 0 ? "is-first" : ""} ${
              isLegend(player) ? "is-legend" : ""
            } ${rankClass(player)}`}
            href={`/player/${player.id}`}
          >
            <div class="rank">{index + 1}</div>

            <div class="avatar-wrap">
              {index === 0 && <div class="crown">♛</div>}

              <img
                class="avatar"
                src={imagePath(player)}
                alt={player.name}
                loading={index < 3 ? "eager" : "lazy"}
                decoding="async"
                onerror="this.src='/players/placeholder-player.webp'"
              />
            </div>

            <div class="player-info">
              <div class="player-name">{player.name}</div>

              <div class="player-meta">
                {player.id} | {player.rank.toUpperCase()}
              </div>
            </div>

            <div class="score">
              <strong>{player.goals}</strong>
              {index === 0 && <span>GOALS</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </main>
</Layout>