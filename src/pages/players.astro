---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getPlayers } from "../lib/players.js";

const players = await getPlayers();

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function byId(a, b) {
  return a.id.localeCompare(b.id, undefined, { numeric: true });
}

function rankClass(player) {
  return `rank-${player.rank?.toLowerCase()}`;
}

const legends = players
  .filter((player) => player.rank?.toLowerCase() === "legend")
  .sort(byId);

const members = players
  .filter((player) => player.rank?.toLowerCase() === "member")
  .sort(byId);

const rookies = players
  .filter((player) => player.rank?.toLowerCase() === "rookie")
  .sort(byId);

const groups = [
  { title: "LEGENDS", players: legends },
  { title: "MEMBERS", players: members },
  { title: "ROOKIES", players: rookies },
];
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PLAYER INDEX | MYSAL STATS</title>
</head>

<body>
<main class="container">

  <Header />

  <section class="player-index-header">
    <h2>PLAYER INDEX</h2>
    <span>{players.length} PLAYERS</span>
  </section>

  {groups.map((group) => (
    <section class="player-group">
      <div class="player-group-head">
        <h2>{group.title}</h2>
        <span>{group.players.length} PLAYERS</span>
      </div>

      <div class="player-index-list">
        {group.players.map((player) => (
          <a class={`player-index-row ${rankClass(player)}`} href={`/player/${player.id}`}>
            <img
              class="avatar"
              src={imagePath(player)}
              alt={player.name}
              onerror="this.src='/players/placeholder-player.webp'"
            />

            <div class="player-info">
              <div class="player-name">{player.name}</div>

              <div class="player-meta">
                <span>{player.id}</span>
                <span>｜</span>
                <span>{player.rank.toUpperCase()}</span>
              </div>
            </div>

            <div class="arrow">›</div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <Footer />

</main>
</body>
</html>