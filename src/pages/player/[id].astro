---
import "../../styles/global.css";
import "../../styles/player.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Layout from "../../layouts/Layout.astro";
import { getPageData } from "../../lib/players.js";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=30, stale-while-revalidate=60"
);

const { players, siteData } = await getPageData();

const { id } = Astro.params;
const player = players.find((p) => p.id === id);

if (!player) {
  return Astro.redirect("/players");
}

const totalPlayers = players.length;

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function rankClass(player) {
  return `rank-${player.rank?.toLowerCase()}`;
}

function getRank(players, targetPlayer, key) {
  const sorted = [...players].sort((a, b) => {
    if (b[key] !== a[key]) return b[key] - a[key];
    if (b.total !== a.total) return b.total - a.total;
    return a.id.localeCompare(b.id, undefined, { numeric: true });
  });

  const index = sorted.findIndex((p) => p.id === targetPlayer.id);

  return index >= 0 ? index + 1 : "-";
}

function rankSuffix(rank) {
  if (rank === 1) return "1ST";
  if (rank === 2) return "2ND";
  if (rank === 3) return "3RD";
  return `${rank}TH`;
}

const goalRank = getRank(players, player, "goals");
const gpgRank = getRank(
  players.filter((p) => p.matches > 0),
  player,
  "rate"
);
const appearanceRank = getRank(players, player, "total");
const momRank = getRank(players, player, "mom");

const bestRecords = [
  { label: "GOALS", rank: goalRank },
  { label: "GPG", rank: gpgRank },
  { label: "APPEARANCES", rank: appearanceRank },
  { label: "MOM", rank: momRank },
].filter((item) => typeof item.rank === "number");

const bestRecord = bestRecords.sort((a, b) => a.rank - b.rank)[0];
---

<Layout
  title={`${player.name} | MYSAL STATS`}
  description={`${player.name}のマイサル公式スタッツページ`}
>
  <main class="container">

    <Header active="players" />

    <section class={`player-profile-card ${rankClass(player)}`}>
      <div class="profile-center">

        <img
          class="profile-avatar"
          src={imagePath(player)}
          alt={player.name}
          decoding="async"
          fetchpriority="high"
          onerror="this.src='/players/placeholder-player.webp'"
        />

        <h1>{player.name}</h1>

        <p class="profile-meta">
          {player.id} | {player.rank.toUpperCase()}
        </p>

        <div class="profile-divider"></div>

        <span class="best-label">BEST RECORD</span>

        <div class="best-rank">
          {rankSuffix(bestRecord.rank)}
        </div>

        <div class="best-category">
          {bestRecord.label}
        </div>
      </div>
    </section>

    <section class="player-stats-card">
      <div class="stats-card-head">
        <div>
          <h2>MONTHLY</h2>
          <p>{siteData.displayMonth}</p>
        </div>

        <span>
          UPDATED<br />
          {siteData.updatedDate}
        </span>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-label">GOALS</span>
          <div class="stat-value">{player.goals}</div>
          <div class="stat-rank">
            RANK {player.goals > 0 ? goalRank : "-"} / {totalPlayers}
          </div>
        </div>

        <div class="stat-card">
          <span class="stat-label">GPG</span>
          <div class="stat-value">{player.rate.toFixed(2)}</div>
          <div class="stat-rank">
            RANK {gpgRank} / {totalPlayers}
          </div>
        </div>
      </div>
    </section>

    <section class="player-stats-card">
      <div class="stats-card-head">
        <div>
          <h2>ALL TIME</h2>
          <p>CAREER RECORDS</p>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-label">APPEARANCES</span>
          <div class="stat-value">{player.total}</div>
          <div class="stat-rank">
            RANK {appearanceRank} / {totalPlayers}
          </div>
        </div>

        <div class="stat-card">
          <span class="stat-label">MOM</span>
          <div class="stat-value">{player.mom}</div>
          <div class="stat-rank">
            RANK {player.mom > 0 ? momRank : "-"} / {totalPlayers}
          </div>
        </div>
      </div>
    </section>

    <div class="back-home">
      <a href="/players">PLAYER INDEX</a>
    </div>

    <Footer />

  </main>
</Layout>