---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getPlayers } from "../../lib/players.js";

const players = await getPlayers();

const { id } = Astro.params;

const player = players.find((p) => p.id === id);

if (!player) {
  return Astro.redirect("/players");
}

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function isLegend(player) {
  return player.rank?.toLowerCase() === "legend";
}

function getRank(players, targetPlayer, key) {
  const sorted = [...players].sort((a, b) => b[key] - a[key]);

  let rank = 1;
  let previousValue = null;
  let previousRank = 1;

  for (let i = 0; i < sorted.length; i++) {
    const currentValue = sorted[i][key];

    if (previousValue !== null && currentValue !== previousValue) {
      rank = i + 1;
    } else {
      rank = previousRank;
    }

    if (sorted[i].id === targetPlayer.id) {
      return rank;
    }

    previousValue = currentValue;
    previousRank = rank;
  }

  return "-";
}

const goalRank = getRank(players, player, "goals");
const rateRank = getRank(players.filter((p) => p.matches > 0), player, "rate");
const momRank = getRank(players, player, "mom");
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{player.name} | MYSAL STATS</title>
</head>

<body>
<main class="container">

  <Header />

  <section class={`hero ${isLegend(player) ? "is-legend" : ""}`}>
    <div class="hero-meta">{player.rank.toUpperCase()}</div>

    <div class="hero-copy">
      <p class="eyebrow">PLAYER PROFILE</p>

      <div class="big-number">{player.goals}</div>
      <p class="unit">GOALS</p>

      <img
        class="hero-image"
        src={imagePath(player)}
        alt={player.name}
        onerror="this.src='/players/placeholder-player.webp'"
      />

      <div class="hero-name-area">
        <h2>{player.name}</h2>
        <p>{player.id} ｜ {player.rank.toUpperCase()}</p>
      </div>
    </div>
  </section>

  <section class="stats-strip" style="margin-bottom:16px;">
    <div><span>GAMES</span><strong>{player.matches}</strong></div>
    <div><span>GOALS</span><strong>{player.goals}</strong></div>
    <div><span>RATE</span><strong>{player.rate.toFixed(2)}</strong></div>
  </section>

  <section class="stats-strip" style="margin-bottom:16px;">
    <div><span>APPEARANCES</span><strong>{player.total}</strong></div>
    <div><span>MOM</span><strong>{player.mom}</strong></div>
    <div><span>RANK</span><strong style="font-size:22px;">{player.rank}</strong></div>
  </section>

  <section class="stats-strip">
    <div><span>GOAL RANK</span><strong>{goalRank}</strong></div>
    <div><span>RATE RANK</span><strong>{rateRank}</strong></div>
    <div><span>MOM RANK</span><strong>{momRank}</strong></div>
  </section>

  <div class="back-home">
    <a href="/players">PLAYER INDEX</a>
  </div>

  <Footer />

</main>
</body>
</html>