---
import "../styles/global.css";
import "../styles/mom.css";
import Header from "../components/Header.astro";
import BackHome from "../components/BackHome.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import { getPageData } from "../lib/players.js";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=30, stale-while-revalidate=60"
);

const { players, siteData } = await getPageData();

const momRanking = [...players]
  .filter((player) => player.mom > 0)
  .sort((a, b) => {
    if (b.mom !== a.mom) return b.mom - a.mom;
    if (b.total !== a.total) return b.total - a.total;
    return a.id.localeCompare(b.id, undefined, { numeric: true });
  })
  .slice(0, 10);

function imagePath(player) {
  return player.photo
    ? `/players/${player.photo}`
    : "/players/placeholder-player.webp";
}

function isLegend(player) {
  return player.rank?.toLowerCase() === "legend";
}
---

<Layout
  title="MOM RANKING | MYSAL STATS"
  description="マイサルの歴代MOMランキング。TOP MOM WINNERSを掲載しています。"
>
  <main class="container">

    <Header />

    <section class="mom-card">

      <div class="mom-card-head">
        <h2>ALL TIME</h2>

        <div class="updated">
          <span>UPDATED</span>
          <strong>{siteData.updatedDate}</strong>
        </div>
      </div>

      <div class="mom-dashed-line"></div>

      <h1 class="mom-title">TOP MOM WINNERS</h1>

      <div class="mom-list">
        {momRanking.map((player, index) => (
          <a
            class={`mom-row ${index === 0 ? "is-first" : ""} rank-${player.rank?.toLowerCase()}`}
            href={`/player/${player.id}`}
          >

            <div class="mom-rank">
              {index + 1}
            </div>

            <div class="mom-avatar-wrap">
              {index === 0 && <div class="crown">♛</div>}

              <img
                class="mom-avatar"
                src={imagePath(player)}
                alt={player.name}
                loading={index < 3 ? "eager" : "lazy"}
                decoding="async"
                onerror="this.src='/players/placeholder-player.webp'"
              />
            </div>

            <div class="mom-name-area">
              <strong>{player.name}</strong>
              <span>{player.id} | {player.rank.toUpperCase()}</span>
            </div>

            <div class="mom-score">
              <strong>{player.mom}</strong>
              {index === 0 && <span>TIMES</span>}
            </div>

          </a>
        ))}
      </div>

    </section>

    <BackHome />

    <Footer />

  </main>
</Layout>