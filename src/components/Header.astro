---
const { active } = Astro.props;

const pathname = Astro.url.pathname;

function isActive(path, name) {
  if (active) {
    return active === name;
  }

  if (path === "/") return pathname === "/";
  return pathname.startsWith(path);
}
---

<header class="site-header">

  <a href="/" style="width:52px;height:52px;display:flex;align-items:center;justify-content:center;">
    <img
      src="/favicon.svg"
      alt="MYSAL"
      style="width:48px;height:48px;object-fit:contain;display:block;"
    />
  </a>

  <div class="header-text">
    <h1>MYSAL STATS</h1>
    <p>MONTHLY LEADERBOARD</p>
  </div>

</header>

<nav class="nav">

  <a class={isActive("/", "home") ? "active" : ""} href="/">
    HOME
  </a>

  <a class={isActive("/goal-ranking", "goals") ? "active" : ""} href="/goal-ranking">
    GOALS
  </a>

  <a class={isActive("/goal-rate", "gpg") ? "active" : ""} href="/goal-rate">
    GPG
  </a>

  <a class={isActive("/mom-ranking", "mom") ? "active" : ""} href="/mom-ranking">
    MOM
  </a>

  <a class={isActive("/players", "players") ? "active" : ""} href="/players">
    PLAYERS
  </a>

</nav>