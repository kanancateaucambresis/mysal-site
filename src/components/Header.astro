---
const { active } = Astro.props;

const pathname = Astro.url.pathname;

function isActive(path, name) {
  if (active) {
    return active === name;
  }

  if (path === "/") return pathname === "/";
  return pathname.startsWith(path);
}
---

<header class="site-header" transition:persist="mysal-site-header">

  <a
    href="/"
    style="width:52px;height:52px;display:flex;align-items:center;justify-content:center;"
  >
    <img
      src="/favicon.svg"
      alt="MYSAL"
      style="width:48px;height:48px;object-fit:contain;display:block;"
    />
  </a>

  <div class="header-text">
    <h1>MYSAL STATS</h1>
    <p>MONTHLY LEADERBOARD</p>
  </div>

</header>

<nav
  class="nav"
  data-mysal-nav
  transition:persist="mysal-main-nav"
>

  <a
    class={isActive("/", "home") ? "active" : ""}
    href="/"
    data-nav-page="home"
  >
    HOME
  </a>

  <a
    class={isActive("/goal-ranking", "goals") ? "active" : ""}
    href="/goal-ranking"
    data-nav-page="goals"
  >
    GOALS
  </a>

  <a
    class={isActive("/goal-rate", "gpg") ? "active" : ""}
    href="/goal-rate"
    data-nav-page="gpg"
  >
    GPG
  </a>

  <a
    class={isActive("/mom-ranking", "mom") ? "active" : ""}
    href="/mom-ranking"
    data-nav-page="mom"
  >
    MOM
  </a>

  <a
    class={isActive("/players", "players") ? "active" : ""}
    href="/players"
    data-nav-page="players"
  >
    PLAYERS
  </a>

</nav>

<script>
  function updateActiveNavigation() {
    const nav = document.querySelector("[data-mysal-nav]");

    if (!nav) return;

    const pathname = window.location.pathname;

    let activePage = "home";

    if (pathname.startsWith("/goal-ranking")) {
      activePage = "goals";
    } else if (pathname.startsWith("/goal-rate")) {
      activePage = "gpg";
    } else if (pathname.startsWith("/mom-ranking")) {
      activePage = "mom";
    } else if (
      pathname.startsWith("/players") ||
      pathname.startsWith("/player/")
    ) {
      activePage = "players";
    }

    nav.querySelectorAll("[data-nav-page]").forEach((link) => {
      link.classList.toggle(
        "active",
        link.getAttribute("data-nav-page") === activePage
      );
    });
  }

  document.addEventListener("astro:page-load", updateActiveNavigation);

  updateActiveNavigation();
</script>